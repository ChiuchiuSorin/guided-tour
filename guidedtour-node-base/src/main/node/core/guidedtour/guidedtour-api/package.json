{
  "name": "@xwiki/contrib-guidedtour-api",
  "version": "1.0.0-SNAPSHOT",
  "license": "LGPL 2.1",
  "author": "XWiki Org Community <contact@xwiki.org>",
  "homepage": "https://xwiki.org/",
  "repository": {
    "type": "git",
    "directory": "guidedtour-node-base/src/main/node/core/guidedtour/guidedtour-api",
    "url": "git+https://github.com/xwiki-contrib/guided-tour.git"
  },
  "bugs": {
    "url": "https://jira.xwiki.org/projects/GUIDEDTOUR/"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "files": [
    "dist",
    "src",
    "!src/**/*.spec.*",
    "!src/**/*.test.*",
    "!src/**/__tests__"
  ],
  "scripts": {
    "api-extractor:ci": "api-extractor run",
    "api-extractor:local": "api-extractor run --local",
    "build": "vite build",
    "clean": "rimraf dist",
    "lint": "eslint \"./src/**/*.{ts,tsx,vue}\" --max-warnings=0",
    "test": "vitest --run",
    "typecheck": "tsc"
  },
  "types": "./dist/index.d.ts",
  "dependencies": {
    "driver.js": "catalog:"
  },
  "peerDependencies": {
    "vue": "3.x"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "catalog:",
    "@xwiki/contrib-guidedtour-dev-config": "workspace:*",
    "@xwiki/platform-tool-apiextractorconfig": "catalog:",
    "@xwiki/platform-tool-tsconfig": "catalog:",
    "@xwiki/platform-tool-tsdocconfig": "catalog:",
    "@xwiki/platform-tool-viteconfig": "catalog:",
    "eslint": "catalog:",
    "happy-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.es.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.umd.js"
        }
      }
    },
    "main": "./dist/index.es.js",
    "types": "./dist/index.d.ts"
  }
}
